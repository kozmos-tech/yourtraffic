# Postgres connection string used by Drizzle and better-auth.
DATABASE_URL="postgresql://user:password@host:5432/database"

# better-auth. Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"

# Base URL of the app. Use http://localhost:3000 in development.
BETTER_AUTH_URL="http://localhost:3000"

# Google sign-in (optional). Create OAuth credentials in the Google Cloud console
# and set the redirect URI to BETTER_AUTH_URL + /api/auth/callback/google.
# Leave both blank to hide the Google button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
